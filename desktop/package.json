{
  "name": "gil-sweep-desktop",
  "version": "1.0.0",
  "private": true,
  "author": "hazeliscoding",
  "license": "Apache-2.0",
  "description": "gil-sweep desktop app (Electron) — what to farm for gil in FFXIV, from live market data.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "e2e": "node e2e/drive.mjs",
    "e2e:packaged": "node e2e/drive.mjs packaged",
    "start": "electron .",
    "package": "electron-builder",
    "package:win": "electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.61.1",
    "typescript": "~5.5.0"
  },
  "build": {
    "appId": "com.gilsweep.app",
    "productName": "gil-sweep",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "hazeliscoding",
      "repo": "gil-sweep"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "data/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
